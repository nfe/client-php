# Copie para .env e preencha com suas credenciais reais.
# O diretório samples/ usa parse_ini_file para ler este arquivo — sem deps.

# Chave principal (emissão, empresas, webhooks)
NFE_API_KEY=

# Chave separada para serviços de dados (CEP/CNPJ/CPF/NF-e query). Opcional.
# Quando ausente, o SDK faz fallback para NFE_API_KEY.
NFE_DATA_API_KEY=

# ID da empresa cadastrada na sua conta NFE.io
NFE_COMPANY_ID=

# Segredo HMAC usado para validar webhooks
NFE_WEBHOOK_SECRET=
